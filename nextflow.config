/*
 * Nextflow configuration for the MeDIP-seq pipeline project.
 *
 * Default usage on the HPC:
 *   conda activate medip-nf
 *   module load singularity/4.2.1
 *   nextflow run . -profile hpc_singularity -resume
 */

manifest {
    name        = 'nf-medip'
    description = 'MeDIP-seq processing, methylation-enrichment matrix generation, and DMR analysis'
    author      = 'Shangying Chen'
    mainScript  = 'main.nf'
    nextflowVersion = '>=24.10.0'
}

params {
    input               = null
    outdir              = 'results'
    genome              = null
    fasta               = null
    gtf                 = null

    aligner             = 'bwa'
    trim_tool           = 'trim_galore'
    min_mapq            = 30
    samtools_exclude_flags = 2820
    coverage_bin_size   = 50
    coverage_normalize_using = 'CPM'
    effective_genome_size = null

    regions             = 'fixed_windows'
    window_size         = 500
    annotation_bed      = null
    cpg_bed             = null
    promoter_bed        = null

    normalize_using     = 'CPM'
    matrix_type         = 'normalized_enrichment'
    analysis_method     = 'none'
    methylation_method  = 'qsea'

    contrast            = null
    dmr_method          = 'qsea'
    dmr_methods         = 'qsea,medips'
    fdr                 = 0.05
    min_abs_log2fc      = 1
    min_cpgs            = 3

    qsea_window_size    = 500
    qsea_bsgenome       = 'BSgenome.Hsapiens.UCSC.hg38'
    qsea_chr_select     = 'chr1,chr2,chr3,chr4,chr5,chr6,chr7,chr8,chr9,chr10,chr11,chr12,chr13,chr14,chr15,chr16,chr17,chr18,chr19,chr20,chr21,chr22,chrX,chrY'
    qsea_fragment_length = 200
    qsea_fragment_sd    = 20
    qsea_cnv_window_size = 2000000
    qsea_min_cpg_density = 1
    qsea_max_cpg_density = 15
    qsea_min_row_sum    = 5
    qsea_use_batch      = true
    qsea_annotate_regions = true
    qsea_txdb          = 'TxDb.Hsapiens.UCSC.hg38.knownGene'
    qsea_orgdb         = 'org.Hs.eg.db'
    qsea_tss_upstream  = 3000
    qsea_tss_downstream = 3000
    qsea_container      = 'docker.io/bioconductor/bioconductor_docker:RELEASE_3_21'
    delta_beta          = 0.2
    qsea_fragment_size  = null
    qsea_enrichment_pattern = 'CG'
    qsea_norm_method    = 'beta'

    medips_window_size  = 500
    medips_extend       = null
    medips_shift        = null

    skip_fastqc         = false
    skip_trimming       = false
    skip_markduplicates = false
    remove_duplicates   = false

    multiqc_title       = 'MeDIP-seq pipeline report'
}

/*
 * Keep runtime reports on by default. These are useful for development,
 * debugging, and later nf-core review.
 */
timeline {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_timeline.html"
    overwrite = true
}

report {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_report.html"
    overwrite = true
}

trace {
    enabled = true
    file    = "${params.outdir}/pipeline_info/execution_trace.txt"
    overwrite = true
}

dag {
    enabled = true
    file    = "${params.outdir}/pipeline_info/pipeline_dag.html"
    overwrite = true
}

/*
 * Baseline process resources.
 * Individual processes should use labels such as low_mem, medium_mem,
 * high_mem, align, qc, or dmr as the pipeline is implemented.
 */
process {
    shell = ['/bin/bash', '-euo', 'pipefail']

    cpus   = 2
    memory = 4.GB
    time   = 2.h

    errorStrategy = 'terminate'
    maxRetries    = 1
    maxErrors     = '-1'

    withLabel: low_mem {
        cpus   = 4
        memory = 12.GB
        time   = 4.h
    }

    withLabel: medium_mem {
        cpus   = 8
        memory = 20.GB
        time   = 12.h
    }

    withLabel: high_mem {
        cpus   = 20
        memory = 40.GB
        time   = 24.h
    }

    /*
     * Backward-compatible alias for the typo in the older config.
     * Prefer label 'high_mem' in new pipeline code.
     */
    withLabel: hign_mem {
        cpus   = 20
        memory = 40.GB
        time   = 24.h
    }

    withLabel: qc {
        cpus   = 2
        memory = 8.GB
        time   = 4.h
    }

    withLabel: trim {
        cpus   = 4
        memory = 8.GB
        time   = 6.h
    }

    withLabel: align {
        cpus   = 12
        memory = 48.GB
        time   = 24.h
    }

    withLabel: bam_filter {
        cpus   = 4
        memory = 12.GB
        time   = 8.h
    }

    withLabel: markdup {
        cpus   = 6
        memory = 24.GB
        time   = 24.h
    }

    withLabel: coverage {
        cpus   = 4
        memory = 16.GB
        time   = 12.h
    }

    withLabel: dmr {
        cpus   = 8
        memory = 32.GB
        time   = 24.h
    }

    withLabel: qsea {
        cpus   = 8
        memory = 40.GB
        time   = 48.h
    }
}

profiles {
    /*
     * Local development profile for tiny tests only.
     */
    local {
        process.executor = 'local'
    }

    /*
     * HPC profile for this server.
     *
     * Before running:
     *   conda activate medip-nf
     *   module load singularity/4.2.1
     */
    hpc_singularity {
        executor {
            name      = 'pbspro'
            queueSize = 10
        }

        process {
            executor = 'pbspro'
            queue    = 'long'

            withLabel: low_mem {
                queue = 'normal'
            }

            withLabel: medium_mem {
                queue = 'long'
            }

            withLabel: high_mem {
                queue = 'large'
            }

            withLabel: hign_mem {
                queue = 'large'
            }

            withLabel: qsea {
                queue = 'large'
            }

            /*
             * Some HPC systems expose Singularity only after loading a module
             * inside the batch job shell. Users should also load the module
             * before launching Nextflow.
             */
            beforeScript = '''
                if command -v module >/dev/null 2>&1; then
                    module load singularity/4.2.1
                fi
            '''
        }

        singularity {
            enabled    = true
            autoMounts = true
            cacheDir   = "${projectDir}/singularity"
        }

        docker {
            enabled = false
        }

        conda {
            enabled = false
        }
    }

    /*
     * Fallback profile if containers are temporarily unavailable.
     * This is useful for development only; nf-core-style execution should
     * prefer containers where possible.
     */
    hpc_conda {
        executor {
            name      = 'pbspro'
            queueSize = 10
        }

        process {
            executor = 'pbspro'
            queue    = 'long'
        }

        conda {
            enabled = true
        }

        singularity {
            enabled = false
        }

        docker {
            enabled = false
        }
    }
}
